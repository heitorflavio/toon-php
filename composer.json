{
    "name": "heitorflavio/toon-php",
    "description": "TOON (Token-Oriented Object Notation) encoder/decoder for PHP - a compact, human-readable serialization format designed for LLM prompts",
    "type": "library",
    "license": "MIT",
    "keywords": ["toon", "serialization", "llm", "json", "encoder", "decoder", "tokens", "prompt"],
    "homepage": "https://github.com/toon-format/spec",
    "require": {
        "php": ">=8.2",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "suggest": {
        "illuminate/support": "To use the Blade directives (@toon, @tooneach) in a Laravel app (^10 || ^11 || ^12)."
    },
    "bin": [
        "bin/toon"
    ],
    "autoload": {
        "psr-4": {
            "Toon\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Toon\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Toon\\Laravel\\ToonServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
